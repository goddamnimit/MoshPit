<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- MoshPit collects no data, runs no analytics, and does no tracking.
	     Camera, microphone, photo library, and local network access are
	     covered by their Info.plist usage-description strings — they are not
	     "required reason APIs" and must not be listed under
	     NSPrivacyAccessedAPITypes (doing so triggers ITMS-91056).
	     The only required-reason API the app links against is UserDefaults,
	     used for on-device app settings (effect order, MIDI CC bindings,
	     tutorial-seen flag, photosensitivity-warning flag) and the local
	     Pro-unlock state (StoreKit entitlement launch cache, offline
	     redeem-code flag). StoreKit 2 itself (Transaction/Product/AppStore)
	     is not a required-reason API and purchase data is collected and
	     disclosed by Apple, not by this app. -->
	<key>NSPrivacyTracking</key>
	<false/>
	<key>NSPrivacyTrackingDomains</key>
	<array/>
	<key>NSPrivacyCollectedDataTypes</key>
	<array/>
	<key>NSPrivacyAccessedAPITypes</key>
	<array>
		<dict>
			<key>NSPrivacyAccessedAPIType</key>
			<string>NSPrivacyAccessedAPICategoryUserDefaults</string>
			<key>NSPrivacyAccessedAPITypeReasons</key>
			<array>
				<!-- CA92.1: access user defaults to read/write information
				     accessible only to the app itself. -->
				<string>CA92.1</string>
			</array>
		</dict>
	</array>
</dict>
</plist>
